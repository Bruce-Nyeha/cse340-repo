<%- messages() %>

<h1>Update Account Information</h1>

<!-- Account Update Form -->
<form action="/account/update" method="post">
  <input type="hidden" name="account_id" value="<%= account_id %>">

  <label>First Name</label>
  <input type="text" name="account_firstname" value="<%= account_firstname %>" required>

  <label>Last Name</label>
  <input type="text" name="account_lastname" value="<%= account_lastname %>" required>

  <label>Email</label>
  <input type="email" name="account_email" value="<%= account_email %>" required>

  <button type="submit">Update Account</button>
</form>

<hr>

<!-- Change Password Form -->
<form action="/account/update-password" method="post">
  <input type="hidden" name="account_id" value="<%= account_id %>">

  <label>New Password</label>
  <input type="password" name="account_password" required>

  <p><small>Password must be at least 8 characters and contain uppercase, lowercase, number and special character.</small></p>

  <button type="submit">Change Password</button>
</form>