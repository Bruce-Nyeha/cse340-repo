<%- messages() %>

<h1>Add New Classification</h1>

<form action="/inv/add-classification" method="post">
  <label for="classification_name">Classification Name:</label><br>
  <input type="text" id="classification_name" name="classification_name" 
         required pattern="[A-Za-z0-9]+" 
         title="Classification name cannot contain spaces or special characters">
  <br><br>
  
  <button type="submit">Add Classification</button>
</form>

<p>
  <a href="/inv">← Back to Inventory Management</a>
</p>